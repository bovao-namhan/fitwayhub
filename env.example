# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Gemini API Key (Get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=Mangolian
# Set to false for managed/remote DBs where user cannot CREATE DATABASE
DB_AUTO_CREATE=true

# Base URL of this app (used for OAuth callback redirects)
APP_BASE_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

# OpenStreetMap (Leaflet.js) - No API key required, uses free tiles from OpenStreetMap contributors

# Frontend configuration (Vite)
# full base address of backend server used by client-side fetches
VITE_API_BASE=http://localhost:3000
# Auto Premium tracking uses Leaflet.js with OpenStreetMap tiles for map-based location tracking

# ── Apple In-App Purchase ──
APPLE_IAP_SHARED_SECRET=your_apple_shared_secret
APPLE_IAP_SANDBOX=true

# ── Google Play In-App Purchase ──
GOOGLE_PLAY_PACKAGE_NAME=com.fitwayhub.app
GOOGLE_PLAY_SERVICE_ACCOUNT=./google-play-service-account.json

# ── Google Cloud Service Account ──
GOOGLE_CLOUD_SERVICE_ACCOUNT_EMAIL=your_service_account_email
GOOGLE_CLOUD_SERVICE_ACCOUNT_ID=your_service_account_id
GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY=your_service_account_key

# ── Cloudflare R2 Storage ──
# Account ID from your Cloudflare dashboard (righthand sidebar → Account ID)
R2_ACCOUNT_ID=your_cloudflare_account_id
# R2 API Token credentials (Cloudflare R2 → Manage API Tokens → Create Token)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# Name of your R2 bucket
R2_BUCKET_NAME=fitwayhub-uploads
# Public URL for the bucket — either the R2.dev subdomain or your custom domain
# Example: https://pub-xxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxx.r2.dev
